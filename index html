<script>
    // SheetDB API Configuration
    const SHEETDB_API = 'https://sheetdb.io/api/v1/eizek3qs2z56o';
    
    let isUnlimited = localStorage.getItem('proForexUnlimited') === 'true';
    let trades = JSON.parse(localStorage.getItem('proForexJournal')) || [];
    let freeTradesLimit = 25;
    let equityChart, monthlyChart;

    // Initialize on load
    document.addEventListener('DOMContentLoaded', function() {
        updateUIForUnlimitedStatus();
        updateStatsAndCharts();
        renderTrades();
    });

    function updateUIForUnlimitedStatus() {
        const freeBadge = document.getElementById('freeBadge');
        const unlimitedBadge = document.getElementById('unlimitedBadge');
        const upgradeBanner = document.getElementById('upgradeBanner');
        const tradesLeftCard = document.getElementById('tradesLeftCard');
        const unlockBtn = document.getElementById('unlockBtn');
        const footer = document.getElementById('footer');

        if (isUnlimited) {
            freeBadge.style.display = 'none';
            unlimitedBadge.style.display = 'inline-block';
            upgradeBanner.classList.remove('show');
            tradesLeftCard.style.display = 'none';
            unlockBtn.style.display = 'none';
            footer.innerHTML = '<p>⭐ Unlimited Access Activated. Happy Trading!</p><p>⚡ Risk Disclaimer: Past performance does not guarantee future results.</p>';
        } else {
            freeBadge.style.display = 'inline-block';
            unlimitedBadge.style.display = 'none';
            tradesLeftCard.style.display = 'block';
            unlockBtn.style.display = 'block';
            
            const tradesLeft = Math.max(0, freeTradesLimit - trades.length);
            document.getElementById('tradesLeft').textContent = tradesLeft;
            
            if (trades.length >= freeTradesLimit) {
                upgradeBanner.classList.add('show');
            } else {
                upgradeBanner.classList.remove('show');
            }
        }
    }

    function showUpgradeModal() {
        document.getElementById('paymentModal').classList.add('show');
    }

    function closeUpgradeModal() {
        document.getElementById('paymentModal').classList.remove('show');
    }

    // Fetch unlock code from SheetDB
    async function fetchUnlockCodeFromSheetDB() {
        try {
            const response = await fetch(SHEETDB_API + '?sheet=unlock_codes');
            const data = await response.json();
            if (data && data.length > 0) {
                // Get the most recent active code
                const activeCode = data.find(item => item.status === 'active');
                if (activeCode) {
                    return activeCode.code;
                }
            }
            return null;
        } catch (error) {
            console.error('Error fetching unlock code:', error);
            return null;
        }
    }

    // Verify unlock code against SheetDB
    async function verifyUnlockCode(code) {
        try {
            const response = await fetch(SHEETDB_API + '?sheet=unlock_codes&code=' + encodeURIComponent(code));
            const data = await response.json();
            if (data && data.length > 0) {
                const record = data[0];
                if (record.status === 'active' && record.used !== 'true') {
                    return true;
                }
            }
            return false;
        } catch (error) {
            console.error('Error verifying code:', error);
            return false;
        }
    }

    // Mark code as used in SheetDB
    async function markCodeAsUsed(code) {
        try {
            await fetch(SHEETDB_API + '/code/' + encodeURIComponent(code), {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ used: 'true', used_date: new Date().toISOString() })
            });
        } catch (error) {
            console.error('Error marking code as used:', error);
        }
    }

    async function unlockFullVersion() {
        const code = prompt("Enter your unlock code:");
        if (!code) return;

        // First check localStorage fallback
        const localCode = localStorage.getItem('dynamicUnlockCode');
        if (code === localCode) {
            activateUnlimited();
            return;
        }

        // Then verify against SheetDB
        const isValid = await verifyUnlockCode(code);
        if (isValid) {
            await markCodeAsUsed(code);
            activateUnlimited();
        } else {
            alert("❌ Invalid or already used code. Contact WhatsApp 0803 295 8122.");
        }
    }

    function activateUnlimited() {
        localStorage.setItem('proForexUnlimited', 'true');
        isUnlimited = true;
        updateUIForUnlimitedStatus();
        alert("✅ Unlimited access activated! You can now add unlimited trades.");
    }

    function getTradingSession(time) {
        const hour = parseInt(time.split(':')[0]);
        if (hour >= 0 && hour < 8) return 'Asian';
        if (hour >= 8 && hour < 16) return 'London';
        return 'New York';
    }

    function calculatePips(pair, entry, exit, type) {
        let pipSize = 0.0001;
        if (pair === 'JPY' || pair === 'XAU') pipSize = 0.01;
        let pips = (exit - entry) / pipSize;
        if (type === 'short') pips = -pips;
        return Math.round(pips * 10) / 10;
    }

    function calculateProfit(pair, entry, exit, lots, type) {
        let pipValue = 10;
        if (pair === 'XAU') pipValue = 10;
        let pips = calculatePips(pair, entry, exit, type);
        return Math.round(pips * lots * pipValue * 100) / 100;
    }

    function calculateRR(entry, exit, sl, tp, type) {
        if (!sl || !tp) return '0:0';
        let risk = Math.abs(entry - sl);
        let reward = Math.abs(tp - entry);
        if (type === 'short') {
            risk = Math.abs(sl - entry);
            reward = Math.abs(entry - tp);
        }
        if (risk === 0) return '0:0';
        let rr = Math.round((reward / risk) * 10) / 10;
        return '1:' + rr;
    }

    function updateStatsAndCharts() {
        const totalTrades = trades.length;
        const wins = trades.filter(t => t.profit > 0).length;
        const losses = totalTrades - wins;
        const winRate = totalTrades > 0 ? Math.round((wins / totalTrades) * 100) : 0;
        const totalPL = trades.reduce((sum, t) => sum + t.profit, 0);
        
        const grossProfit = trades.filter(t => t.profit > 0).reduce((sum, t) => sum + t.profit, 0);
        const grossLoss = Math.abs(trades.filter(t => t.profit < 0).reduce((sum, t) => sum + t.profit, 0));
        const profitFactor = grossLoss > 0 ? (grossProfit / grossLoss).toFixed(2) : grossProfit > 0 ? '∞' : '0.00';
        
        const rrValues = trades.map(t => parseFloat(t.rr.split(':')[1]) || 0).filter(r => r > 0);
        const avgRR = rrValues.length > 0 ? (rrValues.reduce((a, b) => a + b, 0) / rrValues.length).toFixed(1) : '0';
        
        const profits = trades.map(t => t.profit);
        const bestTrade = profits.length > 0 ? Math.max(...profits) : 0;
        const worstTrade = profits.length > 0 ? Math.min(...profits) : 0;
        
        const expectancy = totalTrades > 0 ? (totalPL / totalTrades).toFixed(2) : 0;
        
        let consecutiveWins = 0, maxConsecutiveWins = 0;
        trades.forEach(t => {
            if (t.profit > 0) {
                consecutiveWins++;
                maxConsecutiveWins = Math.max(maxConsecutiveWins, consecutiveWins);
            } else {
                consecutiveWins = 0;
            }
        });
        
        let maxDrawdown = 0, peak = 0, runningPL = 0;
        trades.forEach(t => {
            runningPL += t.profit;
            if (runningPL > peak) peak = runningPL;
            const drawdown = peak - runningPL;
            if (drawdown > maxDrawdown) maxDrawdown = drawdown;
        });
        
        const returns = trades.map(t => t.profit);
        const avgReturn = returns.length > 0 ? returns.reduce((a, b) => a + b, 0) / returns.length : 0;
        const variance = returns.length > 0 ? returns.reduce((sum, r) => sum + Math.pow(r - avgReturn, 2), 0) / returns.length : 0;
        const stdDev = Math.sqrt(variance);
        const sharpeRatio = stdDev > 0 ? (avgReturn / stdDev).toFixed(2) : '0.00';
        
        document.getElementById('totalTrades').textContent = totalTrades;
        document.getElementById('winRate').textContent = winRate + '%';
        document.getElementById('totalPL').textContent = '$' + totalPL.toFixed(0);
        document.getElementById('profitFactor').textContent = profitFactor;
        document.getElementById('avgRR').textContent = '1:' + avgRR;
        document.getElementById('bestTrade').textContent = '$' + bestTrade.toFixed(0);
        document.getElementById('worstTrade').textContent = '$' + worstTrade.toFixed(0);
        document.getElementById('expectancy').textContent = '$' + expectancy;
        document.getElementById('consecutiveWins').textContent = maxConsecutiveWins;
        document.getElementById('maxDrawdown').textContent = '$' + maxDrawdown.toFixed(0);
        document.getElementById('sharpeRatio').textContent = sharpeRatio;
        
        updateEquityChart();
        updateMonthlyChart();
        updatePerformanceBreakdowns();
    }

    function updateEquityChart() {
        const ctx = document.getElementById('equityChart').getContext('2d');
        if (equityChart) equityChart.destroy();
        
        let equity = 0;
        const equityData = trades.map((t, i) => {
            equity += t.profit;
            return equity;
        });
        const labels = trades.map((t, i) => i + 1);
        
        equityChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Equity',
                    data: equityData,
                    borderColor: '#00d4aa',
                    backgroundColor: 'rgba(0, 212, 170, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false },
                    y: { grid: { color: '#1e2268' }, ticks: { color: '#a0a4c0', font: { size: 10 } } }
                }
            }
        });
    }

    function updateMonthlyChart() {
        const ctx = document.getElementById('monthlyChart').getContext('2d');
        if (monthlyChart) monthlyChart.destroy();
        
        const monthlyData = {};
        trades.forEach(t => {
            const month = t.date.substring(0, 7);
            monthlyData[month] = (monthlyData[month] || 0) + t.profit;
        });
        
        const labels = Object.keys(monthlyData).slice(-6);
        const data = labels.map(m => monthlyData[m]);
        
        monthlyChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'P/L',
                    data: data,
                    backgroundColor: data.map(v => v >= 0 ? '#00d4aa' : '#ff6b6b'),
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#a0a4c0', font: { size: 10 } } },
                    y: { grid: { color: '#1e2268' }, ticks: { color: '#a0a4c0', font: { size: 10 } } }
                }
            }
        });
    }

    function updatePerformanceBreakdowns() {
        const sessions = {}, pairs = {}, strategies = {};
        
        trades.forEach(t => {
            sessions[t.session] = (sessions[t.session] || { profit: 0, count: 0 });
            sessions[t.session].profit += t.profit;
            sessions[t.session].count++;
            
            pairs[t.pair] = (pairs[t.pair] || { profit: 0, count: 0 });
            pairs[t.pair].profit += t.profit;
            pairs[t.pair].count++;
            
            const strat = t.strategy || 'Unknown';
            strategies[strat] = (strategies[strat] || { profit: 0, count: 0 });
            strategies[strat].profit += t.profit;
            strategies[strat].count++;
        });
        
        const createHTML = (data) => Object.entries(data)
            .sort((a, b) => b[1].profit - a[1].profit)
            .map(([key, val]) => `
                <div class="perf-item">
                    <span>${key} (${val.count})</span>
                    <span class="perf-value" style="color: ${val.profit >= 0 ? '#00d4aa' : '#ff6b6b'}">$${val.profit.toFixed(0)}</span>
                </div>
            `).join('');
        
        document.getElementById('sessionStats').innerHTML = createHTML(sessions) || '<div class="perf-item"><span>No data</span></div>';
        document.getElementById('pairStats').innerHTML = createHTML(pairs) || '<div class="perf-item"><span>No data</span></div>';
        document.getElementById('strategyStats').innerHTML = createHTML(strategies) || '<div class="perf-item"><span>No data</span></div>';
    }

    function renderTrades() {
        const tbody = document.getElementById('tradesBody');
        const count = document.getElementById('tradeCount');
        
        count.textContent = trades.length + ' trade' + (trades.length !== 1 ? 's' : '');
        
        if (trades.length === 0) {
            tbody.innerHTML = '<tr><td colspan="14" style="text-align:center; padding:40px;">No trades yet. Add your first trade below.</td></tr>';
            return;
        }
        
        tbody.innerHTML = trades.slice().reverse().map((t, i) => `
            <tr>
                <td>${t.date}</td>
                <td>${t.time}</td>
                <td>${t.session}</td>
                <td>${t.pair}</td>
                <td>${t.type}</td>
                <td>${t.entry}</td>
                <td>${t.exit}</td>
                <td>${t.lots}</td>
                <td>${t.pips}</td>
                <td class="${t.profit >= 0 ? 'win' : 'loss'}">$${t.profit}</td>
                <td>${t.rr}</td>
                <td>${t.strategy || '-'}</td>
                <td><button class="share-btn" onclick="shareTrade(${trades.length - 1 - i})">Share</button></td>
                <td><button class="delete-btn" onclick="deleteTrade(${trades.length - 1 - i})">Delete</button></td>
            </tr>
        `).join('');
    }

    function addTrade() {
        if (!isUnlimited && trades.length >= freeTradesLimit) {
            alert("🚫 You've reached your 25 free trades limit. Upgrade to unlimited for ₦2,000 to continue.");
            showUpgradeModal();
            return;
        }
        
        const date = document.getElementById('tradeDate').value;
        const time = document.getElementById('tradeTime').value;
        const pair = document.getElementById('tradePair').value;
        const type = document.getElementById('tradeType').value;
        const lots = parseFloat(document.getElementById('tradeLots').value);
        const entry = parseFloat(document.getElementById('tradeEntry').value);
        const exit = parseFloat(document.getElementById('tradeExit').value);
        const sl = parseFloat(document.getElementById('tradeSL').value) || 0;
        const tp = parseFloat(document.getElementById('tradeTP').value) || 0;
        const strategy = document.getElementById('tradeStrategy').value;
        const notes = document.getElementById('tradeNotes').value;
        
        if (!date || !time || !entry || !exit) {
            alert('Please fill in all required fields');
            return;
        }
        
        const pips = calculatePips(pair, entry, exit, type);
        const profit = calculateProfit(pair, entry, exit, lots, type);
        const rr = calculateRR(entry, exit, sl, tp, type);
        const session = getTradingSession(time);
        
        const trade = {
            id: Date.now(),
            date, time, pair, type, lots, entry, exit, sl, tp,
            pips, profit, rr, session, strategy, notes
        };
        
        trades.push(trade);
        localStorage.setItem('proForexJournal', JSON.stringify(trades));
        
        updateStatsAndCharts();
        renderTrades();
        updateUIForUnlimitedStatus();
        
        // Clear form
        document.getElementById('tradeEntry').value = '';
        document.getElementById('tradeExit').value = '';
        document.getElementById('tradeSL').value = '';
        document.getElementById('tradeTP').value = '';
        document.getElementById('tradeNotes').value = '';
        
        // Check if limit reached after adding
        if (!isUnlimited && trades.length >= freeTradesLimit) {
            setTimeout(() => {
                alert("🎉 You've used all 25 free trades! Upgrade to unlimited for ₦2,000 to continue tracking your trades.");
                showUpgradeModal();
            }, 500);
        }
    }

    function deleteTrade(index) {
        if (confirm('Are you sure you want to delete this trade?')) {
            trades.splice(index, 1);
            localStorage.setItem('proForexJournal', JSON.stringify(trades));
            updateStatsAndCharts();
            renderTrades();
            updateUIForUnlimitedStatus();
        }
    }

    function shareTrade(index) {
        const t = trades[index];
        const text = `📊 Trade Result\n${t.pair} ${t.type.toUpperCase()}\nP/L: $${t.profit} | ${t.pips} pips\nRR: ${t.rr}\n#ForexTrading`;
        if (navigator.share) {
            navigator.share({ title: 'My Trade', text: text });
        } else {
            navigator.clipboard.writeText(text);
            alert('Trade details copied to clipboard!');
        }
    }

    function exportCSV() {
        if (trades.length === 0) {
            alert('No trades to export');
            return;
        }
        const headers = ['Date', 'Time', 'Session', 'Pair', 'Type', 'Entry', 'Exit', 'Lots', 'Pips', 'P/L', 'RR', 'Strategy', 'Notes'];
        const csv = [headers.join(',')];
        trades.forEach(t => {
            csv.push([t.date, t.time, t.session, t.pair, t.type, t.entry, t.exit, t.lots, t.pips, t.profit, t.rr, `"${t.strategy || ''}"`, `"${t.notes || ''}"`].join(','));
        });
        const blob = new Blob([csv.join('\n')], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'forex-journal-' + new Date().toISOString().split('T')[0] + '.csv';
        a.click();
    }

    function importCSV() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.csv';
        input.onchange = function(e) {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = function(event) {
                const text = event.target.result;
                const lines = text.split('\n').slice(1).filter(l => l.trim());
                let imported = 0;
                lines.forEach(line => {
                    const cols = line.split(',');
                    if (cols.length >= 10) {
                        trades.push({
                            id: Date.now() + Math.random(),
                            date: cols[0], time: cols[1], session: cols[2], pair: cols[3],
                            type: cols[4], entry: parseFloat(cols[5]), exit: parseFloat(cols[6]),
                            lots: parseFloat(cols[7]), pips: parseFloat(cols[8]),
                            profit: parseFloat(cols[9]), rr: cols[10] || '0:0',
                            strategy: cols[11]?.replace(/"/g, '') || '',
                            notes: cols[12]?.replace(/"/g, '') || ''
                        });
                        imported++;
                    }
                });
                localStorage.setItem('proForexJournal', JSON.stringify(trades));
                updateStatsAndCharts();
                renderTrades();
                updateUIForUnlimitedStatus();
                alert(`Imported ${imported} trades`);
            };
            reader.readAsText(file);
        };
        input.click();
    }

    function clearAllData() {
        if (confirm('⚠️ Are you sure? This will delete ALL trades permanently!')) {
            trades = [];
            localStorage.removeItem('proForexJournal');
            updateStatsAndCharts();
            renderTrades();
            updateUIForUnlimitedStatus();
            alert('All data cleared');
        }
    }

    function scrollToForm() {
        document.getElementById('formSection').scrollIntoView({ behavior: 'smooth' });
    }
</script>
