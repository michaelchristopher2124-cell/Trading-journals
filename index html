            <div class="form-group"><label>Pair</label><select id="tradePair"><option value="EURUSD">EUR/USD</option><option value="GBPUSD">GBP/USD</option><option value="USDJPY">USD/JPY</option><option value="XAUUSD">XAU/USD</option></select></div>
            <div class="form-group"><label>Type</label><select id="tradeType"><option value="long">Long ↗️</option><option value="short">Short ↙️</option></select></div>
