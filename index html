        <div class="stat-card" id="tradesLeftCard"><div class="stat-label">Trades Left</div><div class="stat-value" id="tradesLeft">25</div></div>
    </div>

    <div class="charts-grid">
        <div class="chart-card"><h4>📈 Equity Curve</h4><canvas id="equityChart"></canvas></div>
        <div class="chart-card"><h4>📊 Monthly P/L</h4><canvas id="monthlyChart"></canvas></div>
    </div>

    <div class="perf-grid">
        <div class="perf-card"><h4>🕒 Session Performance</h4><div id="sessionStats"></div></div>
        <div class="perf-card"><h4>💰 Pair Performance</h4><div id="pairStats"></div></div>
