<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Pro Forex Journal | Track Your Trades</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="manifest" href="manifest.json">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0a0e27;
            color: #ffffff;
            padding: 16px;
            padding-bottom: 80px;
        }
        .container { max-width: 1400px; margin: 0 auto; }

        .header { text-align: center; margin-bottom: 24px; }
        .header h1 { font-size: 1.8rem; background: linear-gradient(135deg, #00d4aa, #00b894); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .header p { font-size: 0.8rem; color: #a0a4c0; }
        .free-badge { display: inline-block; background: #00d4aa; color: #0a0e27; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; margin-top: 8px; }
        .unlimited-badge { display: inline-block; background: linear-gradient(135deg, #ffd700, #ffaa00); color: #0a0e27; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; margin-top: 8px; }

        .stats-dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 12px; margin-bottom: 24px; }
        .stat-card { background: #0f1235; border: 1px solid #1e2268; border-radius: 16px; padding: 12px; text-align: center; }
        .stat-label { font-size: 0.6rem; text-transform: uppercase; color: #a0a4c0; margin-bottom: 4px; }
        .stat-value { font-size: 1rem; font-weight: 700; color: #00d4aa; }

        .upgrade-banner { background: linear-gradient(135deg, #ff6b6b, #ee5a24); border-radius: 20px; padding: 16px; text-align: center; margin-bottom: 20px; display: none; }
        .upgrade-banner.show { display: block; }

        .payment-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .payment-modal.show { display: flex; }
        .payment-content {
            background: #0f1235;
            border: 1px solid #1e2268;
            border-radius: 20px;
            padding: 24px;
            max-width: 400px;
            width: 100%;
            text-align: center;
        }
        .payment-content h3 { color: #00d4aa; margin-bottom: 16px; }
        .account-number {
            background: #1a1e4a;
            border: 2px solid #00d4aa;
            border-radius: 12px;
            padding: 16px;
            margin: 16px 0;
            font-size: 1.2rem;
            font-weight: 700;
            color: #00d4aa;
        }
        .payment-content p { font-size: 0.8rem; color: #a0a4c0; margin: 8px 0; }
        .payment-content .price { font-size: 2rem; font-weight: 700; color: #ffd700; margin: 16px 0; }
        .close-modal {
            background: #1a1e4a;
            border: 1px solid #2a2e6a;
            color: #a0a4c0;
            padding: 10px 24px;
            border-radius: 30px;
            cursor: pointer;
            margin-top: 16px;
        }

        .charts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 20px; }
        .chart-card { background: #0f1235; border: 1px solid #1e2268; border-radius: 16px; padding: 12px; }
        .chart-card h4 { font-size: 0.8rem; margin-bottom: 10px; color: #00d4aa; }
        canvas { max-height: 200px; width: 100%; }

        .perf-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-bottom: 20px; }
        .perf-card { background: #0f1235; border: 1px solid #1e2268; border-radius: 16px; padding: 12px; }
        .perf-card h4 { font-size: 0.8rem; margin-bottom: 10px; color: #00d4aa; }
        .perf-item { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #1e2268; font-size: 0.7rem; }
        .perf-value { color: #00d4aa; font-weight: 600; }

        .action-buttons { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
        .btn-secondary { background: #1a1e4a; border: 1px solid #2a2e6a; color: #a0a4c0; padding: 10px 16px; border-radius: 30px; font-size: 0.75rem; cursor: pointer; flex: 1; text-align: center; }

        .trades-section { background: #0f1235; border: 1px solid #1e2268; border-radius: 20px; padding: 16px; margin-bottom: 20px; }
        .section-title { font-size: 1rem; font-weight: 600; margin-bottom: 16px; color: #00d4aa; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .table-container { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        th, td { padding: 10px 6px; text-align: left; border-bottom: 1px solid #1e2268; }
        th { color: #a0a4c0; font-weight: 600; }
        .win { color: #00d4aa; font-weight: 600; }
        .loss { color: #ff6b6b; font-weight: 600; }
        .delete-btn, .share-btn { background: transparent; border: none; padding: 4px 10px; border-radius: 16px; cursor: pointer; font-size: 0.6rem; margin-right: 5px; }
        .delete-btn { border: 1px solid #ff6b6b; color: #ff6b6b; }
        .share-btn { border: 1px solid #00d4aa; color: #00d4aa; }

        .form-section { background: #0f1235; border: 1px solid #1e2268; border-radius: 20px; padding: 16px; margin-bottom: 20px; }
        .form-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group label { font-size: 0.65rem; color: #a0a4c0; font-weight: 500; }
        .form-group input, .form-group select, .form-group textarea { background: #1a1e4a; border: 1px solid #2a2e6a; padding: 10px; border-radius: 12px; color: white; font-size: 0.75rem; font-family: 'Inter', sans-serif; }
        .full-width { grid-column: span 4; }
        .btn-primary { background: linear-gradient(135deg, #00d4aa, #00b894); color: #0a0e27; border: none; padding: 14px; border-radius: 40px; font-weight: 700; font-size: 0.9rem; cursor: pointer; margin-top: 16px; width: 100%; }

        .footer { text-align: center; font-size: 0.65rem; color: #6a6e8a; margin-top: 20px; }

        @media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
            .full-width { grid-column: span 1; }
            .charts-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
